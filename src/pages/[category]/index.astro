---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Newsletter from '../../components/Newsletter.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, CATEGORY_LABEL, type Category } from '../../content.config';

export async function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { category: c } }));
}

const { category } = Astro.params;
const cat = category as Category;
const label = CATEGORY_LABEL[cat];

const posts = (
  await getCollection('blog', ({ data }) => !data.draft && data.category === cat)
).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function sizeFor(i: number): 'PCF' | 'PCT' | 'PCW' | 'PCN' {
  if (i === 0) return 'PCF';
  if (i < 3) return 'PCT';
  if (i < 5) return 'PCW';
  return 'PCN';
}

const intro = {
  dba: 'Advanced Oracle DBA deep-dives — RAC wait events, AWR interpretation, online partitioning, and the tuning work you actually do on production systems.',
  oci: 'Oracle Cloud Infrastructure and Exadata Cloud — migrations to ExaCS/ExaCC, cross-platform moves, and running Oracle databases at real scale on OCI.',
  goldengate: 'Oracle GoldenGate patterns, bidirectional replication, and zero-downtime schema changes.',
  scripts: 'Ready-to-run SQL and shell scripts for monitoring, diagnostics, and routine DBA work.',
  community: 'Oracle community posts — ACE programme notes, conference writeups, and career-side thoughts.',
}[cat];
---
<BaseLayout
  title={`${label} — OraDiscuss`}
  description={`${label} articles on OraDiscuss: ${intro}`}
>
  <section class="art-hero">
    <div class="art-container">
      <a class="art-back" href="/">← All Articles</a>
      <div class={`art-cat ${cat}`}>{label}</div>
      <h1 class="art-title">{label}</h1>
      <p style="color:var(--ink-3);font-size:17px;line-height:1.65;max-width:700px;margin-top:12px">
        {intro}
      </p>
      <div class="art-meta" style="margin-top:16px">
        <span>
          {posts.length} article{posts.length === 1 ? '' : 's'} · updated
          {posts[0]
            ? posts[0].data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })
            : '—'}
        </span>
      </div>
    </div>
  </section>

  <section id="posts">
    <div class="SW2">
      <div class="BG rv">
        {posts.length === 0 && (
          <div
            style="grid-column:1/-1;padding:40px;background:#fff;border:1px solid var(--border);border-radius:var(--r-md);text-align:center;color:var(--ink-3)"
          >
            <p>No articles in this category yet.</p>
          </div>
        )}
        {posts.map((p, i) => <PostCard post={p} size={sizeFor(i)} />)}
      </div>
    </div>
  </section>

  <Newsletter />
</BaseLayout>
